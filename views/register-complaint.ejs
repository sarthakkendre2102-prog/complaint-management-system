<%- include('partials/header') %>

    <h2>Register Complaint</h2>

    <form action="/complaint/new" method="POST">

        <label>Complaint Title:</label><br>
        <input type="text" name="title" required><br><br>

        <label>Complaint Category:</label><br>
        <select name="category" required>
            <option value="">--Select Category--</option>
            <option>Technical Issue</option>
            <option>Service Issue</option>
            <option>Billing Issue</option>
            <option>Other</option>
        </select><br><br>

        <label>Complaint Description:</label><br>
        <textarea name="description" rows="5" cols="40" required></textarea><br><br>

        <label>Upload Supporting File:</label><br>
        <input type="file" name="file"><br><br>

        <button type="submit">Submit Complaint</button>

    </form>

    <br>
    <a href="/">Back to Home</a>

<%- include('partials/footer') %>
