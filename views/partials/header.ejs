<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Complaint Management System' %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>Complaint Management System</h1>
        <nav>
            <a href="/"><button>Home</button></a>
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'admin') { %>
                    <a href="/dashboard/admin"><button>Admin Dashboard</button></a>
                <% } else { %>
                    <a href="/dashboard/user"><button>My Dashboard</button></a>
                <% } %>
                <a href="/logout"><button>Logout (<%= user.fullname %>)</button></a>
            <% } else { %>
                <a href="/register"><button>Register User</button></a>
                <a href="/login"><button>Login Here</button></a>
            <% } %>
        </nav>
    </header>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
