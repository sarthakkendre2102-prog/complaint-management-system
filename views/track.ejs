<%- include('partials/header') %>

    <h2>Track Your Complaint</h2>

    <form action="/track" method="POST">

        <label>Enter Complaint ID:</label><br>
        <input type="text" name="complaint_id" required><br><br>

        <button type="submit">Track</button>

    </form>

    <br>

    <% if (typeof complaint !== 'undefined' && complaint) { %>
        <div class="status-box">
            <h3>Complaint Status</h3>
            <p><b>Complaint ID:</b> <%= complaint.complaint_id %></p>
            <p><b>Title:</b> <%= complaint.title %></p>
            <p><b>Category:</b> <%= complaint.category %></p>
            <p><b>Description:</b> <%= complaint.description %></p>
            <p><b>Status:</b> <span class="status-badge status-<%= complaint.status.toLowerCase().replace(' ', '-') %>"><%= complaint.status %></span></p>
            <p><b>Email:</b> <%= complaint.user_email %></p>
        </div>
    <% } else if (typeof searched !== 'undefined' && searched) { %>
        <div class="status-box">
            <h3>Complaint not found</h3>
        </div>
    <% } else { %>
        <div class="status-box">
            <h3>Complaint Status:</h3>
            <p>Status will be displayed here</p>
        </div>
    <% } %>

    <br>
    <a href="/">Back to Home</a>

<%- include('partials/footer') %>
